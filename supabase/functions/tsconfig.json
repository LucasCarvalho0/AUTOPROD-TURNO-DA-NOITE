{
  "compilerOptions": {
    "target": "ESNext",
    "lib": ["ESNext"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "noEmit": true,
    "allowImportingTsExtensions": true
  },
  "include": [
    "./**/*.ts"
  ],
  "exclude": [
    "../../../node_modules"
  ]
}
